{
  "name": "cruzonic-stream-bridge",
  "version": "0.1.0",
  "private": true,
  "description": "WebSocket bridge: Twilio Media Streams → STT provider → Supabase Realtime",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "lint": "tsc --noEmit",
    "tunnel": "ngrok http --log=stdout 8080",
    "dev:tunnel": "concurrently -k -n bridge,ngrok -c orange,blue \"npm:dev\" \"npm:tunnel\""
  },
  "dependencies": {
    "@deepgram/sdk": "^3.9.0",
    "@supabase/supabase-js": "^2.100.0",
    "assemblyai": "^4.10.0",
    "dotenv": "^16.4.5",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/ws": "^8.5.13",
    "concurrently": "^9.0.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5"
  }
}
